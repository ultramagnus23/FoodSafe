# FoodSafe India — environment template. Copy to .env and fill in.
#   cp .env.example .env
# .env is gitignored — never commit real credentials.

# ---- Database ----
# Local Postgres:
#   DATABASE_URL=postgresql://postgres@localhost:5432/foodsafe
#
# Supabase: use the IPv4 *Session pooler* connection string from the
# dashboard (Project → Connect → Session pooler). The direct
# db.<ref>.supabase.co host is IPv6-only and unreachable from IPv4-only
# networks. sslmode=require is mandatory.
#   DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres?sslmode=require
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres?sslmode=require

# ---- Auth ----
JWT_SECRET=change-me-in-production
